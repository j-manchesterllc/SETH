generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
  output = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── OPERATOR VAULT (encrypted credentials) ──────────────────────────────
model UserVault {
  id                    String   @id @default(cuid())
  userId                String   @unique
  plaidAccessTokenEncrypted String?
  apifyTokenEncrypted       String?
  socialTokensEncrypted     Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ─── MONEY AGENT: Wealth Arbitrage Events ────────────────────────────────
model MoneyEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String   // YIELD_SPREAD | BROKERAGE_FEE | TAX_LOSS_HARVEST
  payload   Json     // { fromBank, toBank, spread, netAnnualGain, fees }
  status    String   @default("DETECTED") // DETECTED -> CARD_SHOWN -> APPROVED -> EXECUTED
  netProfit Float    // after ALL fees/taxes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
}

// ─── BUSINESS AGENT: Capital Arbitrage Events ────────────────────────────
model BusinessEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String   // WHOLESALE_MARGIN | AD_ROI_ARBITRAGE | SAAS_OVERLAP
  payload   Json     // { product, retailPrice, wholesalePrice, margin, platform, cac, ltv }
  status    String   @default("DETECTED") // DETECTED -> CARD_SHOWN -> APPROVED -> EXECUTED
  netProfit Float    // after ALL fees/taxes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
}

// ─── SECURE DATA BROKER: Trigger Table / Message Board ───────────────────
model BrokerMessage {
  id            String   @id @default(cuid())
  sourceAgent   String   // MONEY | BUSINESS
  targetAgent   String   // MONEY | BUSINESS
  eventType     String   // MONTHLY_CLOSE | RUNWAY_ALERT | SURPLUS_DETECTED | TAX_TIER_CROSSED
  payload       Json     // { netProfit: 15000, runwayDays: 45, surplus: 15000, taxTier: "22%" }
  processed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([sourceAgent, targetAgent])
  @@index([processed])
  @@index([eventType])
}

// ─── OPPORTUNITY CARDS: Friction Rule (1-click approval) ─────────────────
model OpportunityCard {
  id                String   @id @default(cuid())
  sourceEventId     String   // ref to MoneyEvent or BusinessEvent
  sourceEventType   String   // MONEY | BUSINESS
  title             String
  description       String   @db.Text
  netBenefit        Float
  fees              Float
  taxes             Float
  requiresApproval  Boolean  @default(true)
  approved          Boolean  @default(false)
  executed          Boolean  @default(false)
  createdAt         DateTime @default(now())
  approvedAt        DateTime?
  executedAt        DateTime?

  @@index([sourceEventId])
  @@index([approved])
  @@index([executed])
}

// ─── EMERGENCY RUNWAY: Liquidity Threshold (NEVER TOUCHED) ───────────────
model EmergencyRunway {
  id          String   @id @default(cuid())
  userId      String   @unique
  amountCents Int      // protected minimum in cents
  currency    String   @default("USD")
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ─── AGENT BUS MESSAGES (for multi-agent communication) ─────────────────
model BusMessage {
  id              String   @id @default(cuid())
  source          String   // SETH | AEGIS | HERMES | CLAW | GHOST | QUANTUM
  target          String   // SETH | AEGIS | HERMES | CLAW | GHOST | QUANTUM
  messageType     String
  payload         Json
  priority        Int      @default(2) // 1=high, 2=normal, 3=low
  status          String   @default("pending") // pending | delivered | failed
  sourceSessionId String?
  createdAt       DateTime @default(now())
  deliveredAt     DateTime?

  @@index([source, target])
  @@index([status])
}