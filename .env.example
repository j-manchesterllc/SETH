# ─── SETH Environment Configuration ─────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Supabase ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Authentication ──────────────────────────────────────────────
NEXTAUTH_SECRET=           # Generate with: openssl rand -base64 32
# NEXTAUTH_URL is auto-configured per environment — do not set manually

# ─── Google SSO (optional) ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── AI Model Providers ──────────────────────────────────────────
VENICE_API_KEY=            # Venice.ai — privacy-first model routing
OPENROUTER_API_KEY=        # OpenRouter — free/paid model fallback chain

# ─── Vercel AI Gateway ───────────────────────────────────────────
# Auto-injected by Vercel at runtime — do NOT set manually in production.
# For local dev: run `vercel env pull .env.local` to get a short-lived token.
# VERCEL_OIDC_TOKEN=       # GPT-4o / GPT-5.5 via Vercel AI Gateway (OIDC auth)

# ─── Voice & Media (optional) ────────────────────────────────────
ELEVENLABS_API_KEY=        # Text-to-speech for voice responses
SKYBOX_API_KEY=            # Immersive environment generation

# ─── Browser Automation (optional) ───────────────────────────────
BROWSERLESS_API_TOKEN=     # Headless browser for web automation tasks

# ─── Abacus AI (embeddings, transcription, LLM) ─────────────────
ABACUSAI_API_KEY=          # Abacus AI platform API key for embeddings & LLM

# ─── Internal ────────────────────────────────────────────────────
CRON_SECRET=               # Secret for authenticating scheduled cron jobs

# ─── Seed Data (optional — only needed for db seeding) ───────────
SEED_USER_EMAIL=           # Default test user email
SEED_USER_PASSWORD=        # Default test user password
